{
  "name": "tradingcopier",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "infra/cdk"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "build": "npm run -w backend build && npm run -w frontend build && npm run -w infra/cdk build",
    "test": "npm run -w backend test",
    "local:dynamodb": "docker compose -f docker-compose.local.yml up -d",
    "local:table": "npm run -w backend local:create-table",
    "local:api": "npm run -w backend dev:local-api",
    "local:web": "npm run -w frontend dev",
    "local:be": "npm run -w backend dev:be-automation"
  }
}
