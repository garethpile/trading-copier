# Local API server
LOCAL_API_PORT=4000
LOCAL_AUTH_BYPASS=true
LOCAL_USER_ID=local-user

# Local DynamoDB
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
DYNAMODB_ENDPOINT=http://localhost:8000
TRADE_SIGNALS_TABLE=TradeSignalsLocal

# Execution and validation
EXECUTION_PROVIDER=mock
ALLOWED_TARGET_ACCOUNTS=a5231bf5-8713-44b6-846d-4c7f43a5bf30
LOT_SIZE_MIN=0.01
LOT_SIZE_MAX=50
REQUIRE_PROTECTIVE_LEVELS=true
AUTOMATION_USER_ID=local-user
BREAKEVEN_POLL_MS=5000
METACOPIER_SOCKET_URL=wss://api.metacopier.io/ws/api/v1
BREAKEVEN_DEBUG=false

# Not required when EXECUTION_PROVIDER=mock
# METACOPIER_SECRET_ARN=
# METACOPIER_BASE_URL=https://api-london.metacopier.io
# METACOPIER_GLOBAL_BASE_URL=https://api.metacopier.io
# METACOPIER_REQUEST_TIMEOUT_MS=25000

# Optional: required by some project-level keys
# METACOPIER_USER_EMAIL=you@example.com
